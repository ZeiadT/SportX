                <activityIndicatorView opaque="NO" contentMode="scaleToFill" horizontalHuggingPriority="750" verticalHuggingPriority="750" hidesWhenStopped="YES" style="large" translatesAutoresizingMaskIntoConstraints="NO" id="leagues-activity-ind">
                    <rect key="frame" x="188.5" y="429.5" width="37" height="37"/>
