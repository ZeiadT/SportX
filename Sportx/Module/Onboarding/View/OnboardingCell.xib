<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="19529" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <device id="retina6_1" orientation="portrait" appearance="light"/>
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="19519"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <collectionViewCell opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" reuseIdentifier="OnboardingCell" id="oc-cell" customClass="OnboardingCell" customModule="SportX" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="375" height="667"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
            <collectionViewCellContentView key="contentView" opaque="NO" clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="center" insetsLayoutMarginsFromSafeArea="NO" id="oc-content">
                <rect key="frame" x="0.0" y="0.0" width="375" height="667"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>
                    <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" image="sportscourt" catalog="system" translatesAutoresizingMaskIntoConstraints="NO" id="oc-img">
                        <rect key="frame" x="127.5" y="253.5" width="120" height="120"/>
                        <constraints>
                            <constraint firstAttribute="width" constant="120" id="oc-imgw"/>
                            <constraint firstAttribute="height" constant="120" id="oc-imgh"/>
                        </constraints>
                    </imageView>
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Welcome to SportX" textAlignment="center" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="oc-title">
                        <rect key="frame" x="32" y="405.5" width="311" height="68"/>
                        <fontDescription key="fontDescription" type="boldSystem" pointSize="28"/>
                        <color key="textColor" systemColor="labelColor"/>
                    </label>
                    <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Your ultimate companion for all sports." textAlignment="center" numberOfLines="0" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="oc-subtitle">
                        <rect key="frame" x="32" y="489.5" width="311" height="60"/>
                        <fontDescription key="fontDescription" type="system" pointSize="16"/>
                        <color key="textColor" systemColor="secondaryLabelColor"/>
                    </label>
                </subviews>
                <color key="backgroundColor" systemColor="systemBackgroundColor"/>
                <constraints>
                    <constraint firstItem="oc-img" firstAttribute="centerX" secondItem="oc-content" secondAttribute="centerX" id="oc-imgcx"/>
                    <constraint firstItem="oc-img" firstAttribute="centerY" secondItem="oc-content" secondAttribute="centerY" constant="-80" id="oc-imgcy"/>
                    <constraint firstItem="oc-title" firstAttribute="top" secondItem="oc-img" secondAttribute="bottom" constant="32" id="oc-titletop"/>
                    <constraint firstItem="oc-title" firstAttribute="leading" secondItem="oc-content" secondAttribute="leading" constant="32" id="oc-titleleading"/>
                    <constraint firstItem="oc-content" firstAttribute="trailing" secondItem="oc-title" secondAttribute="trailing" constant="32" id="oc-titletrailing"/>
                    <constraint firstItem="oc-subtitle" firstAttribute="top" secondItem="oc-title" secondAttribute="bottom" constant="16" id="oc-subtitletop"/>
                    <constraint firstItem="oc-subtitle" firstAttribute="leading" secondItem="oc-content" secondAttribute="leading" constant="32" id="oc-subtitleleading"/>
                    <constraint firstItem="oc-content" firstAttribute="trailing" secondItem="oc-subtitle" secondAttribute="trailing" constant="32" id="oc-subtitletrailing"/>
                </constraints>
            </collectionViewCellContentView>
            <connections>
                <outlet property="imageView" destination="oc-img" id="oc-c1"/>
                <outlet property="titleLabel" destination="oc-title" id="oc-c2"/>
                <outlet property="subtitleLabel" destination="oc-subtitle" id="oc-c3"/>
            </connections>
            <point key="canvasLocation" x="132" y="71"/>
